#cloud-config
autoinstall:
  version: 1
  locale: en_US.UTF-8
  keyboard:
    layout: us
  storage:
    layout:
      name: lvm
  identity:
    hostname: ubuntu-template
    username: ansible
    # This is a placeholder password - SSH key auth is the real mechanism
    # Password: changeme (bcrypt hash)
    password: "$6$rounds=4096$..."
  ssh:
    install-server: true
    authorized-keys:
      - "{{ .SSHPublicKey }}"
    allow-pw: false
  packages:
    - qemu-guest-agent
    - curl
    - wget
    - git
    - vim
    - htop
    - unzip
    - ca-certificates
    - python3
    - python3-pip
    - fail2ban
    - ntp
  late-commands:
    - systemctl enable qemu-guest-agent